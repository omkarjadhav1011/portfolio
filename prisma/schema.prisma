generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id              String   @id @default(cuid())
  slug            String   @unique
  repoName        String
  description     String
  language        String
  languageColor   String
  stars           Int      @default(0)
  forks           Int      @default(0)
  commits         Int      @default(0)
  lastCommit      String
  lastCommitMsg   String
  tags            String   // JSON: string[]
  liveUrl         String?
  repoUrl         String?
  status          String   @default("active")
  pinned          Boolean  @default(false)
  longDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CommitEntry {
  id          String   @id @default(cuid())
  hash        String   @unique
  type        String
  title       String
  org         String
  date        String
  dateEnd     String?
  description String   // JSON: string[]
  branch      String
  branchColor String
  colorKey    String?
  tags        String?  // JSON: string[]
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SkillBranch {
  id         String   @id @default(cuid())
  branchName String   @unique
  color      String
  offset     Int      @default(0)
  skills     Skill[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Skill {
  id        String      @id @default(cuid())
  name      String
  level     Int
  tag       String?
  icon      String?
  branchId  String
  branch    SkillBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([branchId, name])
}

model SkillDiff {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id               String   @id @default("main")
  name             String
  handle           String
  headline         String
  bio              String
  currentBranch    String
  currentStatus    String
  availableForWork Boolean  @default(true)
  email            String
  location         String
  socials          String   // JSON: SocialLink[]
  funFacts         String   // JSON: string[]
  stash            String?  // JSON: string[]
  updatedAt        DateTime @updatedAt
}
