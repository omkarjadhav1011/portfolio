# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Turso (https://turso.tech) — hosted SQLite database
# Get these from: turso db show <db-name> --url  &&  turso db tokens create <db-name>
TURSO_DATABASE_URL= url
TURSO_AUTH_TOKEN=token
# Local SQLite fallback (only used when TURSO_* vars are absent)
DATABASE_URL=file:./prisma/dev.db

# JWT secret for admin auth (any random 32+ char string)
JWT_SECRET=your-random-secret-here

# Admin password — generate with:
# node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=
# Resend (https://resend.com) — for contact form emails
RESEND_API_KEY=re_your_api_key_here

# Your email address to receive contact form submissions
CONTACT_TO_EMAIL=your@email.com

# Anthropic (https://console.anthropic.com) — powers the portfolio AI assistant
ANTHROPIC_API_KEY=sk-ant-...
